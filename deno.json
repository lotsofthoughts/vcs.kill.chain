{
  "version": "1.0.0",
  "name": "@softdist/vcs-agent",
  "license": "MIT",
  "exports": "./src/mod.ts",
  "test": {
    "include": [
      "src/tests/"
    ]
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "strict": true,
    "types": []
  },
  "publish": {
    "include": [
      "./src/**/*.ts",
      "!./src/tests/**"
    ]
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": true
  },
  "lint": {
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/tests/fixtures/**"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "include": [
        "ban-untagged-todo"
      ],
      "exclude": [
        "no-explicit-any",
        "no-unused-vars",
        "require-await"
      ]
    }
  },
  "tasks": {
    "start": "deno run --allow-all ./src/mod.ts",
    "dev": "deno run --watch --allow-all ./src/mod.ts",
    "test": "deno test -A --parallel src/tests/",
    "test:unit": "deno test -A --parallel src/tests/unit/",
    "test:integration": "deno test -A src/tests/integration/",
    "test:external": "deno test -A src/tests/integration/external/",
    "build": "deno run --allow-all src/make_version.ts",
    "check": "deno check src/mod.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "compile": "make compile",
    "upgrade": "deno outdated --update --latest",
    "validate-hooks": "deno run -A npm:lefthook validate",
    "pre-commit": "deno run -A npm:lefthook run pre-commit",
    "pre-push": "deno run -A npm:lefthook run pre-push"
  },
  "imports": {
    "@cliffy/command": "jsr:@cliffy/command@^1.0.0-rc.7",
    "@cliffy/prompt": "jsr:@cliffy/prompt@^1.0.0-rc.7",
    "@std/assert": "jsr:@std/assert@1.0.13",
    "@std/async": "jsr:@std/async@^1.0.12",
    "@std/collections": "jsr:@std/collections@^1.0.11",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/fmt": "jsr:@std/fmt@^1.0.7",
    "@std/fs": "jsr:@std/fs@^1.0.17",
    "@std/path": "jsr:@std/path@^1.0.9",
    "@std/semver": "jsr:@std/semver@^1.0.5",
    "@std/testing": "jsr:@std/testing@^1.0.11",
    "@std/yaml": "jsr:@std/yaml@^1.0.5",
    "lefthook": "npm:lefthook@^1.11.12",
    "tweetnacl": "npm:tweetnacl@^1.0.3",
    "tweetnacl-util": "npm:tweetnacl-util@^0.15.1"
  }
}
